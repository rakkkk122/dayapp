# .npmrc — Konfigurasi npm untuk Daily Life Manager
# Mengatasi masalah spesifik Termux Android

# Penting: ignore scripts bisa skip postinstall yang error di Termux
# Tapi kita PUNYA postinstall prisma generate, jadi biarkan default (false)
# ignore-scripts=false

# Paksa platform android-arm64 kalau auto-detect salah
# (Untuk Termux Android)
target_platform=linux
target_arch=arm64

# Paksa npm tidak update minor/patch version Prisma
# (sudah di-pin ke exact version di package.json, tapi ini extra safety)
save-exact=true

# Reduce noise
fund=false
audit=false

# Timeout lebih lama untuk koneksi lambat di HP
fetch-timeout=300000
fetch-retries=5
